  "keyFeatures": [
    "Real-time cryptocurrency trading with live market data",
    "High-performance in-memory order execution engine",
    "Microservices architecture with Redis and WebSockets",
    "Time-series data storage with TimeScaleDB",
    "Complete user authentication and balance management",
    "Advanced charting with multiple timeframes",
    "Docker-ready deployment with compose orchestration"
  ],
  "publicApiSurface": [
    "POST /api/v1/auth/login - User authentication via email",
    "POST /api/v1/auth/verify - Verify authentication token",
    "GET /api/v1/balance - Get user account balance",
    "GET /api/v1/supportedAssets - List supported trading assets",
    "GET /api/v1/candles - Retrieve historical candle data",
    "POST /api/v1/trade/create - Create new trading order",
    "POST /api/v1/trade/close - Close existing order",
    "GET /api/v1/trade/orders - Get user's order history",
    "WebSocket ws://localhost:7070 - Real-time price updates"
  ]
